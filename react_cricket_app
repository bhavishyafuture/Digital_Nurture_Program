import React from 'react';

function ListofPlayers() {
  const players = [
    { name: "Player1", score: 45 },
    { name: "Player2", score: 78 },
    { name: "Player3", score: 65 },
    { name: "Player4", score: 90 },
    { name: "Player5", score: 30 },
    { name: "Player6", score: 88 },
    { name: "Player7", score: 55 },
    { name: "Player8", score: 72 },
    { name: "Player9", score: 40 },
    { name: "Player10", score: 60 },
    { name: "Player11", score: 95 }
  ];

  const playerNames = players.map(p => `${p.name}: ${p.score}`);
  const lowScorePlayers = players.filter(p => p.score < 70);

  return (
    <div>
      <h2>All Players</h2>
      {playerNames.map((p, index) => <p key={index}>{p}</p>)}

      <h2>Players with score below 70</h2>
      {lowScorePlayers.map((p, index) => <p key={index}>{p.name}: {p.score}</p>)}
    </div>
  );
}

export default ListofPlayers;

