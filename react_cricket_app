import React from 'react';

function IndianPlayers() {
  const oddTeam = { player1: "Rohit", player3: "Kohli", player5: "Rahul" };
  const evenTeam = { player2: "Dhawan", player4: "Pant", player6: "Jadeja" };

  const { player1, player3, player5 } = oddTeam;
  const { player2, player4, player6 } = evenTeam;

  const T20players = ["Rohit", "Kohli", "Pant"];
  const RanjiTrophyPlayers = ["Mayank", "Pujara", "Iyer"];

  const mergedPlayers = [...T20players, ...RanjiTrophyPlayers];

  return (
    <div>
      <h2>Odd Team Players</h2>
      <p>{player1}, {player3}, {player5}</p>

      <h2>Even Team Players</h2>
      <p>{player2}, {player4}, {player6}</p>

      <h2>Merged Players (T20 + Ranji Trophy)</h2>
      {mergedPlayers.map((p, index) => <p key={index}>{p}</p>)}
    </div>
  );
}

export default IndianPlayers;

